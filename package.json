{
  "name": "cosider",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:shared": "turbo run build --filter=@cosider/shared",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write",
    "check-types": "turbo run check-types",
    "prepare": "husky"
  },
  "devDependencies": {
    "@cosider/eslint-config": "workspace:^",
    "eslint": "^10.4.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "turbo": "^2.9.16",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "yarn@4.14.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,yaml,md,vue,html}": [
      "prettier --write"
    ]
  }
}
